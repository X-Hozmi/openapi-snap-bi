APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_DEFAULT_CONNECTION=mysql

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=openapi_snap_bi
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET="utf8mb4"
DB_COLLATION="utf8mb4_0900_ai_ci"

DB_TESTING_CONNECTION=mysql
DB_TESTING_HOST=127.0.0.1
DB_TESTING_PORT=3306
DB_TESTING_DATABASE=openapi_snap_bi
DB_TESTING_USERNAME=root
DB_TESTING_PASSWORD=
DB_TESTING_CHARSET="utf8mb4"
DB_TESTING_COLLATION="utf8mb4_0900_ai_ci"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

SANITIZER_ADDITIONAL_HEADERS="authorization,cookie,x-xsrf-token,x-client-key,x-client-secret,x-partner-id,x-signature,private-key,set-cookie,x-unique,x-path"
SANITIZER_ADDITIONAL_PAYLOADS="id,password,password_confirmation,passwordConfirmation,token,token_type,tokenType,access_token,accessToken,refresh_token,refreshToken,clientSecret,signature"

RATE_LIMIT_OPENAPI=30

OAUTH_OPENAPI_SELF_CHANNEL_ID=
OAUTH_OPENAPI_SELF_PARTNER_ID=
OAUTH_OPENAPI_SELF_CLIENT_KEY=
OAUTH_OPENAPI_SELF_CLIENT_SECRET=
OAUTH_OPENAPI_SELF_IP_ADDRESS=127.0.0.1
OAUTH_OPENAPI_SELF_PUBLIC_KEY_FILE="oauth-public.key"
OAUTH_OPENAPI_SELF_PRIVATE_KEY_FILE="oauth-private.key"
OAUTH_OPENAPI_SELF_SCOPE=""